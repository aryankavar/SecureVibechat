rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isChatParticipant(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId));
      return isAuthenticated() && request.auth.uid in chat.data.participants;
    }

    function isRateLimited() {
      // Basic rate limiting: requires clients to space out creates
      // This is hard to enforce strictly without Cloud Functions tracking previous writes,
      // but we can enforce timestamp validity.
      return request.time == request.resource.data.createdAt;
    }
    
    function isValidMessage() {
      let msg = request.resource.data;
      return msg.keys().hasAll(['senderId', 'type', 'status', 'createdAt']) &&
             msg.senderId == request.auth.uid &&
             (msg.type == 'text' || msg.type == 'image' || msg.type == 'video' || msg.type == 'audio' || msg.type == 'file' || msg.type == 'sticker') &&
             (msg.keys().hasAll(['content']) || msg.keys().hasAll(['ciphertexts'])) &&
             msg.status in ['sending', 'sent', 'delivered', 'read'] &&
             msg.createdAt == request.time;
    }
    
    // System messages are only created by Cloud Functions, so they bypass client rules.
    // Client-side rule only validates user-sent messages.

    // -------------------------------------------------------------------------
    // Users Collection
    // -------------------------------------------------------------------------
    match /users/{userId} {
      // Any authenticated user can read public profiles
      allow read: if isAuthenticated();
      
      // Users can only create/update their own profile
      // Note: publicKey might not be mandatory anymore for new users, but keeping it for backward compatibility.
      allow create: if isUser(userId) 
                   && request.resource.data.keys().hasAll(['uid', 'displayName'])
                   && request.resource.data.uid == userId;
                   
      allow update: if isUser(userId)
                   // Prevent modifying the UID
                   && request.resource.data.uid == resource.data.uid;
                   
      // No deletions allowed directly from client
      allow delete: if false;
      
      // User Settings Subcollection (Strictly private)
      match /settings/{settingDoc} {
        allow read, write: if isUser(userId);
      }
      
      // Devices Subcollection (Public keys for multi-device)
      match /devices/{deviceId} {
        allow read: if isAuthenticated();
        allow write: if isUser(userId);
      }

      // -----------------------------------------------------------------
      // Key Backups Subcollection
      // Only the owning user can read/write their own PIN-encrypted key
      // backups. This prevents any other user from accessing or tampering
      // with another user's encrypted key material.
      // -----------------------------------------------------------------
      match /keyBackups/{backupId} {
        allow read, write: if isUser(userId);
      }
    }
    
    // -------------------------------------------------------------------------
    // Chats Collection
    // -------------------------------------------------------------------------
    match /chats/{chatId} {
      // Must be a participant to read the chat metadata
      allow read: if isAuthenticated() && 
                 (resource == null || request.auth.uid in resource.data.participants);
      
      // Creating a chat requires being a participant
      allow create: if isAuthenticated() && 
                   request.auth.uid in request.resource.data.participants;
      
      // -----------------------------------------------------------------
      // Chat update rule — strict field-level validation
      // -----------------------------------------------------------------
      allow update: if isAuthenticated() && 
                   request.auth.uid in resource.data.participants &&

                   // IMMUTABILITY: participants array must never change after
                   // creation. Allowing mutation would let a malicious client
                   // add or remove users from an existing conversation.
                   request.resource.data.participants == resource.data.participants &&

                   // IMMUTABILITY: chat type (dm vs group) is set at creation
                   // and must never change. Changing it could bypass permission
                   // logic that branches on type.
                   request.resource.data.type == resource.data.type;

                   // Allowed mutable fields: lastMessage, lastMessageTime,
                   // unreadCount, groupInfo.name, groupInfo.description,
                   // groupInfo.avatarUrl, currentEpoch, disappearingMessages
                   
      allow delete: if false; // Chats cannot be deleted, only archived
      
      // -----------------------------------------------------------------
      // Messages Subcollection — strict sender/receiver split
      // -----------------------------------------------------------------
      match /messages/{messageId} {
        // Must be a chat participant to read messages
        allow read: if isChatParticipant(chatId);
        
        // Creating a message
        allow create: if isChatParticipant(chatId) && isValidMessage();
        
        // -----------------------------------------------------------------
        // Message update — split into SENDER vs RECEIVER permissions
        //
        // SENDER can: soft-delete (isDeleted, deletedAt, deletedBy) and
        //             edit (editedText, editedAt).
        // RECEIVER can: update delivery/read status (status, deliveredAt),
        //               read receipts (readBy), and reactions.
        //
        // NEITHER can change immutable fields enforced below.
        // -----------------------------------------------------------------
        allow update: if isChatParticipant(chatId) &&

                     // IMMUTABILITY: senderId must never change after creation.
                     // A malicious client could impersonate another user by
                     // rewriting the sender field on an existing message.
                     request.resource.data.senderId == resource.data.senderId &&

                     // IMMUTABILITY: createdAt must never change. Tampering
                     // with timestamps could reorder message history or
                     // circumvent time-based deletion windows.
                     request.resource.data.createdAt == resource.data.createdAt &&

                     // IMMUTABILITY: message type must not change. Switching
                     // type (e.g. text → image) after creation could break
                     // rendering logic or bypass content validation.
                     request.resource.data.type == resource.data.type &&

                     // IMMUTABILITY: original encrypted content must not be
                     // overwritten. If content were mutable, an attacker
                     // could replace ciphertext after the fact, breaking
                     // the E2EE integrity guarantee.
                     (
                       // If the original message had 'content', it must stay the same
                       (!resource.data.keys().hasAny(['content']) || request.resource.data.content == resource.data.content) &&
                       // If the original message had 'ciphertexts', it must stay the same
                       (!resource.data.keys().hasAny(['ciphertexts']) || request.resource.data.ciphertexts == resource.data.ciphertexts)
                     ) &&

                     // Role-based field access: only the sender OR a non-sender
                     // participant may update, with different allowed fields.
                     (
                       // SENDER path: can soft-delete or edit their own message
                       (resource.data.senderId == request.auth.uid) ||

                       // RECEIVER path: can update status, readBy, reactions,
                       // deliveredAt for read receipts and reactions only
                       (resource.data.senderId != request.auth.uid &&
                        // Receivers must not change sender-only fields
                        request.resource.data.get('isDeleted', resource.data.get('isDeleted', false)) == resource.data.get('isDeleted', false) &&
                        request.resource.data.get('deletedAt', resource.data.get('deletedAt', null)) == resource.data.get('deletedAt', null) &&
                        request.resource.data.get('deletedBy', resource.data.get('deletedBy', null)) == resource.data.get('deletedBy', null) &&
                        request.resource.data.get('editedText', resource.data.get('editedText', null)) == resource.data.get('editedText', null) &&
                        request.resource.data.get('editedAt', resource.data.get('editedAt', null)) == resource.data.get('editedAt', null)
                       )
                     );
                     
        // Messages are never actually deleted, just marked as deleted
        allow delete: if false;
      }

      // -----------------------------------------------------------------
      // Group Keys Subcollection
      // Stores per-device wrapped group keys for E2EE group messaging.
      // Any chat participant can read (to decrypt) and write (to
      // distribute new epoch keys). Restricted to participants only
      // to prevent key leakage to non-members.
      // -----------------------------------------------------------------
      match /groupKeys/{deviceId} {
        allow read: if isChatParticipant(chatId);
        allow write: if isChatParticipant(chatId);
      }
    }
    
    // -------------------------------------------------------------------------
    // Friend Requests Collection
    // -------------------------------------------------------------------------
    match /friendRequests/{userId}/incoming/{requestId} {
      // User can read their own incoming requests
      allow read: if isUser(userId);
      
      // Anyone can CREATE a request for this user
      allow create: if isAuthenticated() && 
                   request.resource.data.senderId == request.auth.uid &&
                   request.resource.data.receiverId == userId;
                   
      // Only the receiver can UPDATE or DELETE (accept/reject)
      allow update, delete: if isUser(userId);
    }
    
    match /friendRequests/{userId}/sent/{requestId} {
      allow read: if isUser(userId);
      allow create, delete: if isUser(userId);
      allow update: if false;
    }
    
    // -------------------------------------------------------------------------
    // Friends Collection
    // -------------------------------------------------------------------------
    match /friends/{userId}/list/{friendId} {
      allow read: if isUser(userId);
      // Client-side should ideally NOT write here directly without a Cloud Function,
      // but if doing batch writes on accept:
      allow create, delete: if isUser(userId);
      allow update: if false;
    }
    
    // -------------------------------------------------------------------------
    // Notifications Collection
    // -------------------------------------------------------------------------
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      
      // ONLY Cloud Functions should create notifications
      allow create: if false;
      
      // Users can update their own (to mark as read)
      allow update: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      
      allow delete: if false;
    }
    
    // -------------------------------------------------------------------------
    // WebRTC Signals (Legacy/Fallback if RTDB is not used)
    // -------------------------------------------------------------------------
    match /webrtc-signals/{chatId} {
      allow read, write: if isChatParticipant(chatId);
      
      match /signals/{signalId} {
        allow read, write: if isChatParticipant(chatId);
      }
    }
  }
}
